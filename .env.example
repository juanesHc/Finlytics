# Plantilla de variables de entorno. Copia este archivo a ".env" y rellena.
# El archivo ".env" real NUNCA se sube al repositorio (está en .gitignore).

# --- PostgreSQL ---
POSTGRES_USER=finlytics
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=finlytics

# Cadena de conexión que usará Python (psycopg).
# host = localhost porque el contenedor expone el puerto 5432 a tu máquina.
DATABASE_URL=postgresql://finlytics:cambia_esta_clave@localhost:5432/finlytics

# --- Claves de API (se usan más adelante, en la Fase 2) ---
FMP_API_KEY=
ANTHROPIC_API_KEY=
