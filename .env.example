# Plantilla de variables de entorno. Copia este archivo a ".env" y rellena.
# El ".env" real NUNCA se sube al repositorio (esta en .gitignore).

# --- PostgreSQL (solo para el docker-compose local) ---
POSTGRES_USER=finlytics
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=finlytics

# Cadena de conexion que usa Python (psycopg).
#  - docker-compose: el servicio "web" ya la sobrescribe a host "db" (red interna).
#  - venv local:     host "localhost" (el contenedor de la BD expone el 5432).
#  - Render:         usa la "Internal Database URL" del Postgres gestionado.
DATABASE_URL=postgresql://finlytics:cambia_esta_clave@localhost:5432/finlytics

# --- FMP (Financial Modeling Prep) ---
FMP_API_KEY=
BASE_URL_FMP=https://financialmodelingprep.com/stable

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
MAX_TOKENS=400
# Prompt de sistema para el veredicto (instrucciones de formato/tono).
PROMPT_INSTRUCCIONES=
# Prompt de sistema para el chatbot.
CHAT_SYSTEM_PROMPT=
